{
  "name": "@uxland/uxland",
  "private": true,
  "devDependencies": {
    "@types/ramda": "0.26.40",
    "@commitlint/cli": "^8.3.5",
    "@commitlint/config-conventional": "^8.3.4",
    "@types/cucumber": "^6.0.1",
    "@types/jest": "^25.1.0",
    "cucumber": "^6.0.5",
    "current-git-branch": "^1.1.0",
    "lerna": "^3.16.4",
    "ts-jest": "^25.2.0",
    "jest-cucumber": "^2.0.11",
    "jest-extended": "^0.11.5"
  },
  "description": "UXLand Libraries",
  "main": "index.js",
  "scripts": {
    "deps:clean": "rimraf node_modules yarn.lock packages/**/node_modules",
    "deps:install": "yarn install",
    "deps:refresh": "yarn deps:clean && yarn deps:install",
    "build:clean": "rimraf packages/**/lib packages/**/es",
    "build": "lerna run build",
    "readme:coverage": "lerna run readme:coverage",
    "release:dry-run": "lerna run semantic-release:dry-run",
    "release": "yarn build && yarn test && yarn readme:coverage && node scripts/publish.js",
    "test": "lerna run test",
    "build:test": "lerna run build:test",
    "precommit": "yarn test && yarn build:test && yarn readme:coverage && git add ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uxland/uxland.git"
  },
  "author": "UXLand <dev@uxland.es>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/uxland/uxland/issues"
  },
  "homepage": "https://github.com/uxland/uxland#readme",
  "workspaces": [
    "packages/*"
  ],
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "node ./scripts/pre-commit.js"
    }
  },
  "dependencies": {
    "ramda": "0.26.1",
    "husky": "^4.2.1"
  }
}
